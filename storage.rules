rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /user_photos/{allPaths=**} {
      // Allow authenticated users to upload their own photos or admins to register anyone
      allow read: if request.auth != null;
      allow write: if request.auth != null; 
    }
    
    match /session_qrs/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null; // Faculty creates QRs
    }
  }
}
