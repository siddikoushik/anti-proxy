rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check role safely
    function getRole() {
      // First try to look up by Auth UID matching the document ID
      let directPath = /databases/$(database)/documents/users/$(request.auth.uid);
      // We can't do a where() query in security rules, but typically the app ensures 
      // the faculty can create a session because their Auth UID matches a user doc.
      // If direct path exists, return that role.
      return exists(directPath) ? get(directPath).data.role : 'none';
      // NOTE: Because of Firestore rule limitations, we strongly recommend migrating the app 
      // to make the document ID equal to the Firebase Auth UID. 
    }

    // Users collection
    match /users/{userId} {
      // Allow public read so unauthenticated students can check if their Roll Number exists for OTP
      allow read: if true;
      // Allow creation by any authenticated user because Admin Bootstrap might not have matching Auth UID
      // The UI strictly hides the Registration screen from non-admins.
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && (getRole() == 'admin' || userId == request.auth.uid);
    }

    // Pending OTPs
    match /pending_otps/{userId} {
      allow create: if true; // Unauthenticated students request OTPs here
      allow read: if true;   // Unauthenticated students verify their OTP here
      allow update: if true; // Unauthenticated students mark their OTP as consumed
    }

    // Class Sessions
    match /class_sessions/{sessionId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null;
      
      // Attendance subcollection
      match /attendance/{studentDocId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
        allow update: if request.auth != null;
      }
    }
  }
}
