rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check role safely
    // IMPORTANT: Admin document ID MUST be the Firebase Auth UID
    function getRole() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(path) ? get(path).data.role : 'none';
    }

    // Users collection
    match /users/{userId} {
      allow read: if request.auth != null;
      // Admin can write any user. User can write their own profile if Doc ID == Auth UID.
      allow write: if request.auth != null && (getRole() == 'admin' || userId == request.auth.uid);
    }

    // Pending OTPs
    match /pending_otps/{userId} {
      allow create: if request.auth != null; // Students request
      allow read: if request.auth != null;
      allow update: if request.auth != null && (getRole() == 'admin' || userId == request.auth.uid);
    }

    // Class Sessions
    match /class_sessions/{sessionId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && getRole() == 'faculty';
      allow update, delete: if request.auth != null && 
        (getRole() == 'admin' || resource.data.faculty_auth_uid == request.auth.uid);
      
      // Attendance subcollection
      match /attendance/{studentDocId} {
        allow read: if request.auth != null && 
          (getRole() in ['faculty', 'admin'] || studentDocId == request.auth.uid);
        
        allow create: if request.auth != null && getRole() == 'faculty';
        
        allow update: if request.auth != null && (
          (getRole() == 'faculty') ||
          (getRole() == 'student' && 
           get(/databases/$(database)/documents/class_sessions/$(sessionId)).data.status == 'open' &&
           request.resource.data.status == 'present' &&
           request.resource.data.marked_by == 'student')
        );
      }
    }
  }
}
